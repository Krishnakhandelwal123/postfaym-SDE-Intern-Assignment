{
  "info": {
    "name": "User Payout Management System",
    "description": "API collection for the payout system. Run requests in order for the full PDF fixture flow.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "userId", "value": "" },
    { "key": "brandId", "value": "" },
    { "key": "saleId1", "value": "" },
    { "key": "saleId2", "value": "" },
    { "key": "saleId3", "value": "" },
    { "key": "withdrawalId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Setup",
      "item": [
        {
          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('userId', pm.response.json().id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"externalId\": \"john_doe\"\n}"
            },
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "Create Brand",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('brandId', pm.response.json().id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"brand_1\"\n}"
            },
            "url": "{{baseUrl}}/brands"
          }
        }
      ]
    },
    {
      "name": "Sales",
      "item": [
        {
          "name": "Create Sale 1 (₹40)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('saleId1', pm.response.json().id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"brandId\": \"{{brandId}}\",\n  \"earningPaise\": 4000\n}"
            },
            "url": "{{baseUrl}}/sales"
          }
        },
        {
          "name": "Create Sale 2 (₹40)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('saleId2', pm.response.json().id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"brandId\": \"{{brandId}}\",\n  \"earningPaise\": 4000\n}"
            },
            "url": "{{baseUrl}}/sales"
          }
        },
        {
          "name": "Create Sale 3 (₹40)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('saleId3', pm.response.json().id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"brandId\": \"{{brandId}}\",\n  \"earningPaise\": 4000\n}"
            },
            "url": "{{baseUrl}}/sales"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Run Advance Payout Job",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/admin/advance-payout-job/run"
          }
        },
        {
          "name": "Reconcile Sale 1 - Rejected",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"rejected\"\n}"
            },
            "url": "{{baseUrl}}/admin/sales/{{saleId1}}/reconcile"
          }
        },
        {
          "name": "Reconcile Sale 2 - Approved",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"approved\"\n}"
            },
            "url": "{{baseUrl}}/admin/sales/{{saleId2}}/reconcile"
          }
        },
        {
          "name": "Reconcile Sale 3 - Approved",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"approved\"\n}"
            },
            "url": "{{baseUrl}}/admin/sales/{{saleId3}}/reconcile"
          }
        }
      ]
    },
    {
      "name": "Wallet",
      "item": [
        {
          "name": "Get Balance",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/users/{{userId}}/balance"
          }
        },
        {
          "name": "Get Ledger History",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/users/{{userId}}/ledger?limit=50&offset=0"
          }
        }
      ]
    },
    {
      "name": "Withdrawals",
      "item": [
        {
          "name": "Initiate Withdrawal",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('withdrawalId', pm.response.json().id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amountPaise\": 2000\n}"
            },
            "url": "{{baseUrl}}/users/{{userId}}/withdrawals"
          }
        },
        {
          "name": "Resolve Withdrawal - Success",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"outcome\": \"success\"\n}"
            },
            "url": "{{baseUrl}}/withdrawals/{{withdrawalId}}/resolve"
          }
        },
        {
          "name": "Resolve Withdrawal - Failed",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"outcome\": \"failed\"\n}"
            },
            "url": "{{baseUrl}}/withdrawals/{{withdrawalId}}/resolve"
          }
        }
      ]
    }
  ]
}
